{
  "Version": "1.0.0",
  "LastUpdated": "2026-03-27",
  "Settings": {
    "CreateRestorePointByDefault": true,
    "AutoExit": false,
    "LogEnabled": false,
    "LogPath": "%TEMP%\\PotatoPS",
    "Theme": "Dark",
    "Language": "ru-RU"
  },
  "Modules": {
    "SoftwareInstaller": {
      "Enabled": true,
      "WingetAutoInstall": true,
      "ShowDescriptions": true
    },
    "SystemClear": {
      "Enabled": true,
      "DefaultSelection": ["Telemetry", "TempFiles", "Bloatware"]
    },
    "Diagnostics": {
      "Enabled": true,
      "QuickScan": false
    },
    "RemoveAI": {
      "Enabled": true,
      "BackupMode": true,
      "WarnOnPowerShell7": true
    },
    "Debloat": {
      "Enabled": true,
      "SafeModeOnly": true
    }
  }
}
